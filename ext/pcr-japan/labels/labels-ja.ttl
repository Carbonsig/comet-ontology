# ── PCRbase clause vocabulary — Japanese labels ──────────────────────────────
# These terms label the 65 PCRbase clause_keys in Japanese,
# enabling cross-lingual querying of extracted PCR requirements.

<https://pcrbase.org/v1/clause/id.operator>
    rdfs:label "プログラムオペレーター"@ja ; skos:prefLabel "プログラムオペレーター"@ja .
<https://pcrbase.org/v1/clause/id.program>
    rdfs:label "プログラム名"@ja ; skos:prefLabel "プログラム名"@ja .
<https://pcrbase.org/v1/clause/id.pcr_number>
    rdfs:label "PCR登録番号"@ja ; skos:prefLabel "PCR登録番号"@ja .
<https://pcrbase.org/v1/clause/id.version>
    rdfs:label "バージョン"@ja ; skos:prefLabel "バージョン"@ja .
<https://pcrbase.org/v1/clause/id.pub_date>
    rdfs:label "発行日"@ja ; skos:prefLabel "発行日"@ja .
<https://pcrbase.org/v1/clause/id.expiry_date>
    rdfs:label "有効期限"@ja ; skos:prefLabel "有効期限"@ja .
<https://pcrbase.org/v1/clause/id.cpc_code>
    rdfs:label "CPCコード"@ja ; skos:prefLabel "CPCコード"@ja .
<https://pcrbase.org/v1/clause/id.geography>
    rdfs:label "対象地域"@ja ; skos:prefLabel "対象地域"@ja .
<https://pcrbase.org/v1/clause/id.language>
    rdfs:label "文書言語"@ja ; skos:prefLabel "文書言語"@ja .
<https://pcrbase.org/v1/clause/scope.product_category>
    rdfs:label "製品カテゴリー定義"@ja ; skos:prefLabel "製品カテゴリー"@ja .
<https://pcrbase.org/v1/clause/scope.intended_use>
    rdfs:label "意図した使用"@ja ; skos:prefLabel "意図した使用"@ja .
