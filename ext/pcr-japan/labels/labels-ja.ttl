comet-pj:PaperPlasticProducts
    rdfs:label      "紙・プラスチック製品"@ja ;
    skos:prefLabel  "紙・プラスチック製品"@ja .

comet-pj:TextilesFootwearApparel
    rdfs:label      "繊維・履物・衣料品"@ja ;
    skos:prefLabel  "繊維・履物・衣料品"@ja .

comet-pj:FurnitureOtherGoods
    rdfs:label      "家具・その他製品"@ja ;
    skos:prefLabel  "家具・その他製品"@ja .

comet-pj:VehiclesTransportEquipment
    rdfs:label      "車両・輸送機器"@ja ;
    skos:prefLabel  "車両・輸送機器"@ja .

comet-pj:ElectricitySteamFuels
    rdfs:label      "電力・蒸気・燃料"@ja ;
    skos:prefLabel  "電力・蒸気・燃料"@ja .

comet-pj:InfrastructureBuildings
    rdfs:label      "インフラ・建物"@ja ;
