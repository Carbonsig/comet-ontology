@prefix rdfs:     <http://www.w3.org/2000/01/rdf-schema#> .
@prefix skos:     <http://www.w3.org/2004/02/skos/core#> .
@prefix comet:    <https://comet.carbon/v1/core#> .
@prefix comet-pcf: <https://comet.carbon/v1/pcf#> .
@prefix comet-eac: <https://comet.carbon/v1/eac#> .
@prefix comet-pj:  <https://comet.carbon/ext/pcr-japan#> .

# =============================================================================
# COMET PCR Japan Extension — Japanese Labels (ja)
# Language: ja (日本語)
# Coverage: COMET core + PCF + PCR-Japan extension — 85 terms
# Source:   Expert LCA/EPD terminology, JIS standards, SuMPO program documents
# =============================================================================

# ── COMET Core (L1–L3) ──────────────────────────────────────────────────────
comet:ProductCarbonFootprint
    rdfs:label      "製品カーボンフットプリント"@ja ;
    skos:prefLabel  "製品カーボンフットプリント"@ja ;
    skos:altLabel   "PCF"@ja ;
    skos:definition "製品のライフサイクル全体にわたる温室効果ガス排出量の総量。"@ja .

comet:Product
    rdfs:label      "製品"@ja ;
    skos:prefLabel  "製品"@ja .

comet:Process
    rdfs:label      "プロセス"@ja ;
    skos:prefLabel  "プロセス"@ja ;
    skos:definition "製品の製造または使用に関連する単位プロセスまたはプロセス群。"@ja .

comet:Material
    rdfs:label      "材料"@ja ;
    skos:prefLabel  "材料"@ja ;
    skos:altLabel   "素材"@ja .

comet:Emission
    rdfs:label      "排出量"@ja ;
    skos:prefLabel  "排出量"@ja ;
    skos:definition "温室効果ガスの大気中への排出。"@ja .

comet:ActivityData
    rdfs:label      "活動量データ"@ja ;
    skos:prefLabel  "活動量データ"@ja ;
    skos:definition "排出量算定に使用する活動量（例：燃料消費量、電力使用量）。"@ja .

comet:DataQualityIndicator
    rdfs:label      "データ品質指標"@ja ;
    skos:prefLabel  "データ品質指標"@ja ;
    skos:definition "LCAデータの時間的・地理的・技術的代表性の評価指標。"@ja .

comet:LifeCycleStage
    rdfs:label      "ライフサイクル段階"@ja ;
    skos:prefLabel  "ライフサイクル段階"@ja ;
    skos:altLabel   "LCI段階"@ja .

comet:SystemBoundary
    rdfs:label      "システム境界"@ja ;
    skos:prefLabel  "システム境界"@ja ;
    skos:definition "製品システムに含まれるプロセスの範囲。どの段階・フローを算定対象とするかを定める。"@ja .

comet:FunctionalUnit
    rdfs:label      "機能単位"@ja ;
    skos:prefLabel  "機能単位"@ja ;
    skos:altLabel   "宣言単位"@ja ;
    skos:definition "製品システムの性能を定量化するための基準単位。PCRで規定される。"@ja .

comet:AllocationMethod
    rdfs:label      "配分方法"@ja ;
    skos:prefLabel  "配分方法"@ja ;
    skos:definition "複数の製品・サービスを生産するプロセスに対するインプット・アウトプットの配分方法。"@ja .

comet:Scenario
    rdfs:label      "シナリオ"@ja ;
    skos:prefLabel  "シナリオ"@ja ;
    skos:definition "使用段階・廃棄段階のパラメータを定める想定条件の集合。"@ja .

# ── COMET PCF Extension (L4) ────────────────────────────────────────────────
comet-pcf:PCRDocument
    rdfs:label      "製品カテゴリルール文書"@ja ;
    skos:prefLabel  "PCR文書"@ja ;
    skos:altLabel   "製品カテゴリルール"@ja , "PCR"@ja ;
    skos:definition "特定の製品カテゴリに対するEPD算定ルールを規定する規範的文書。ISO 14025に基づく。"@ja .

comet-pcf:PCRProgramOperator
    rdfs:label      "PCRプログラムオペレーター"@ja ;
    skos:prefLabel  "プログラムオペレーター"@ja ;
    skos:definition "PCRを発行・管理し、EPD登録プログラムを運営する組織。"@ja .

comet-pcf:governedByPCR
    rdfs:label      "PCRによって管理される"@ja ;
    skos:prefLabel  "PCR管理関係"@ja ;
    skos:definition "製品カーボンフットプリントとそれを管理するPCR文書を結ぶキーストーンプロパティ。"@ja .

comet-pcf:DeclaredModule
    rdfs:label      "宣言モジュール"@ja ;
    skos:prefLabel  "宣言モジュール"@ja ;
    skos:definition "EPDに含まれるライフサイクルモジュール（A1〜D）。EN 15804またはISO 21930で定義される。"@ja .

comet-pcf:ReferenceServiceLife
    rdfs:label      "基準耐用年数"@ja ;
    skos:prefLabel  "基準耐用年数"@ja ;
    skos:altLabel   "RSL"@ja ;
    skos:definition "PCRが規定する製品の標準的な耐用年数。使用段階シナリオの算定基準となる。"@ja .

comet-pcf:CutOffRule
    rdfs:label      "カットオフルール"@ja ;
    skos:prefLabel  "カットオフルール"@ja ;
    skos:definition "インベントリへの算入を省略できる質量・エネルギー・環境負荷の閾値。"@ja .

comet-pcf:ContentDeclaration
    rdfs:label      "コンテンツ申告"@ja ;
    skos:prefLabel  "コンテンツ申告"@ja ;
    skos:definition "EPDに含まれる製品成分・有害物質・生物由来炭素の申告情報。"@ja .

comet-pcf:CircularFootprintFormula
    rdfs:label      "循環フットプリント式（CFF）"@ja ;
    skos:prefLabel  "循環フットプリント式"@ja ;
    skos:altLabel   "CFF"@ja ;
    skos:definition "EN 15804+A2で規定されるリサイクル材料・廃棄段階の配分手法。"@ja .

comet-pcf:EFImpactCategory
    rdfs:label      "EF影響カテゴリ"@ja ;
    skos:prefLabel  "EF影響カテゴリ"@ja ;
    skos:definition "EU環境フットプリント（EF 3.1）の16の影響カテゴリ。PEFCR・EN 15804+A2で必須。"@ja .

# ── COMET EAC (L5) ──────────────────────────────────────────────────────────
comet-eac:Certification
    rdfs:label      "認証"@ja ;
    skos:prefLabel  "認証"@ja ;
    skos:definition "第三者機関による環境パフォーマンスの検証・認証。"@ja .

# ── PCR Japan Extension classes ─────────────────────────────────────────────
comet-pj:SuMPOPCRDocument
    rdfs:label      "SuMPO PCR文書"@ja ;
    skos:prefLabel  "SuMPO PCR文書"@ja ;
    skos:definition "SuMPO環境ラベルプログラムが発行するPCR文書。ISO 21930またはEN 15804に準拠。"@ja .

comet-pj:EcoLeafDeclaration
    rdfs:label      "エコリーフ環境ラベル宣言"@ja ;
    skos:prefLabel  "エコリーフ宣言"@ja ;
    skos:definition "SuMPOエコリーフラベルプログラムの下で発行されるEPD。"@ja .

comet-pj:ISO21930PCR
    rdfs:label      "ISO 21930 PCR"@ja ;
    skos:prefLabel  "ISO 21930 PCR"@ja ;
    skos:definition "ISO 21930に正式準拠したSuMPO PCR。"@ja .

comet-pj:LegacyEcoLeafPCR
    rdfs:label      "旧エコリーフPCR"@ja ;
    skos:prefLabel  "旧エコリーフPCR"@ja ;
    skos:definition "PA-NNNNNN-XX-NN形式の旧登録番号を使用するSuMPO PCR（2024年以前）。"@ja .

comet-pj:SuMPOOperator
    rdfs:label      "一般社団法人サステナブル経営推進機構（SuMPO）"@ja ;
    skos:prefLabel  "SuMPO"@ja ;
    skos:altLabel   "サステナブル経営推進機構"@ja .

# ── PCR Japan properties ────────────────────────────────────────────────────
comet-pj:pcrOverviewJa
    rdfs:label      "PCR適用範囲概要（日本語）"@ja ;
    skos:prefLabel  "PCR適用範囲概要"@ja .

comet-pj:validityPeriodJa
    rdfs:label      "有効期間（日本語）"@ja ;
    skos:prefLabel  "有効期間"@ja .

comet-pj:workingGroupMember
    rdfs:label      "PCRワーキンググループメンバー"@ja ;
    skos:prefLabel  "WGメンバー"@ja .

comet-pj:pcrRegistrationNumber
    rdfs:label      "SuMPO PCR登録番号"@ja ;
    skos:prefLabel  "PCR登録番号"@ja .

comet-pj:japanesePCRField
    rdfs:label      "PCR製品分野（日本）"@ja ;
    skos:prefLabel  "製品分野"@ja .

