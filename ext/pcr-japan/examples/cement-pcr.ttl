    comet-pj:pcrRegistrationNumber "PA-180000-AJ-08" ;
    comet-pcf:version "rev08" ;
    comet-pcf:programOperator comet-pj:SuMPOOperator ;
    comet-pj:japanesePCRField comet-pj:ConstructionProducts ;
    dcterms:source <https://ecoleaf-label.jp/en/pcr/9> .

