<https://api.carbonsig.com/alignments/comet-verifier-export-v4>
    a owl:Ontology ;
    dcterms:title "COMET ↔ CarbonSig Verifier Export v4 Alignment"@en ;
    dcterms:description "Crosswalk from the CarbonSig Verifier Hub export contract (v4) to the COMET ontology. Generated from crosswalk.ts; certainty is recorded as a High/Medium/Low note on each csig: target term."@en ;
    owl:versionInfo "4.0.0" .

# System.(class)  (certainty: Medium)
<https://comet.carbon/v1/pcf#SystemBoundary> skos:broadMatch <https://api.carbonsig.com/schemas/verifier-export/v4#System> .
<https://api.carbonsig.com/schemas/verifier-export/v4#System> rdfs:label "System.(class)"@en ;
    skos:note "[certainty: Medium] A System is the boundary within which processes and flows produce one or more product PCFs. COMET splits this into SystemBoundary + the resulting ProductCarbonFootprint(s)."@en .

# System.systemId  (certainty: Low)
<https://comet.carbon/v1/pcf#ProductCarbonFootprint.pcfId> skos:relatedMatch <https://api.carbonsig.com/schemas/verifier-export/v4#System.systemId> .
<https://api.carbonsig.com/schemas/verifier-export/v4#System.systemId> rdfs:label "System.systemId"@en ;
    skos:note "[certainty: Low] System identifier; loosely the study/PCF id. Primarily graph-wiring."@en .

# System.role  (certainty: Low)
